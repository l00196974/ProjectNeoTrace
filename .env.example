# LLM API 配置
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# LLM 配置
LLM_PROVIDER=openai  # openai 或 anthropic
LLM_MODEL=gpt-3.5-turbo  # 或 claude-2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=500

# 数据路径
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATA_LABELS_DIR=data/labels
DATA_MODELS_DIR=data/models

# 模型配置
STUDENT_MODEL_HIDDEN_DIM=64
STUDENT_MODEL_INTENT_DIM=11
STUDENT_MODEL_EMBEDDING_DIM=128

PROJECTION_HEAD_INPUT_DIM=256
PROJECTION_HEAD_HIDDEN_DIM=128
PROJECTION_HEAD_OUTPUT_DIM=128

# 训练配置
STUDENT_MODEL_EPOCHS=30
STUDENT_MODEL_BATCH_SIZE=32
STUDENT_MODEL_LR=0.001

SUPCON_EPOCHS=30
SUPCON_BATCH_SIZE=16
SUPCON_LR=0.001
SUPCON_TEMPERATURE=0.07

# 推理服务配置
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# 日志配置
LOG_LEVEL=INFO
LOG_DIR=logs
